// ClubSpark — Admin Service Prisma Schema
// Owns the admin schema: admin_users (portal RBAC)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  output          = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["admin"]
}

model AdminUser {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id")       // auth provider subject (supabase UUID / azure object_id)
  tenantId  String   @map("tenant_id") @db.Uuid
  role      String                         // super | bookings | membership | website | coaching | reports
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([userId, tenantId])
  @@map("admin_users")
  @@schema("admin")
  @@index([tenantId])
  @@index([userId])
}

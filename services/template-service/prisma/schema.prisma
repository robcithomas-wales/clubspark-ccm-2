// ClubSpark — Template Service Prisma Schema
// Replace this with the service-specific schema.
//
// Convention:
//   - Each service owns its own schema (booking.*, venue.*, customer.*, etc.)
//   - Cross-service data access goes via HTTP API, never via direct DB query
//   - Use @@map and @map to match existing PostgreSQL snake_case column names

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public"] // Replace with service schema: ["booking"] or ["venue"] etc.
}


// ClubSpark — People Service Prisma Schema
// Owns the people schema: persons, lifecycle_history, tags, person_tags, person_roles, households, person_relationships

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  output          = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["people"]
}

model Customer {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String    @map("tenant_id") @db.Uuid
  firstName           String?   @map("first_name")
  lastName            String?   @map("last_name")
  email               String?
  phone               String?
  marketingConsent    Boolean   @default(false) @map("marketing_consent")
  consentRecordedAt   DateTime? @map("consent_recorded_at")

  // Address
  addressLine1        String?   @map("address_line1")
  addressLine2        String?   @map("address_line2")
  city                String?
  county              String?
  postcode            String?
  country             String?   @default("GB")

  // People platform fields
  lifecycleState      String    @default("active") @map("lifecycle_state")
  lifecycleChangedAt  DateTime? @map("lifecycle_changed_at")
  source              String?   @default("admin")
  dateOfBirth         DateTime? @map("date_of_birth") @db.Date
  avatarUrl           String?   @map("avatar_url")
  commsPreferences    Json      @default("{}") @map("comms_preferences")
  engagementScore     Int?      @map("engagement_score")
  engagementBand      String?   @map("engagement_band")
  lastActivityAt      DateTime? @map("last_activity_at")
  mergedIntoId        String?   @map("merged_into_id") @db.Uuid
  isPrimary           Boolean   @default(true) @map("is_primary")

  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at")

  lifecycleHistory      LifecycleHistory[]
  personTags            PersonTag[]
  personRoles           PersonRole[]
  householdMemberships  HouseholdMember[]
  relationshipsFrom     PersonRelationship[] @relation("RelationshipFrom")
  relationshipsTo       PersonRelationship[] @relation("RelationshipTo")

  @@map("persons")
  @@schema("people")
  @@index([tenantId])
  @@index([tenantId, email])
  @@index([tenantId, lifecycleState])
  @@index([tenantId, engagementBand])
  @@index([tenantId, lastActivityAt])
}

model LifecycleHistory {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  fromState  String?  @map("from_state")
  toState    String   @map("to_state")
  reason     String?
  changedBy  String?  @map("changed_by")
  changedAt  DateTime @default(now()) @map("changed_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("lifecycle_history")
  @@schema("people")
  @@index([customerId, changedAt])
  @@index([tenantId])
}

model Tag {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  colour    String?
  source    String   @default("manual")
  createdAt DateTime @default(now()) @map("created_at")

  personTags PersonTag[]

  @@unique([tenantId, name])
  @@map("tags")
  @@schema("people")
  @@index([tenantId])
}

model PersonRole {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  customerId   String    @map("customer_id") @db.Uuid
  role         String
  contextType  String?   @map("context_type")
  contextId    String?   @map("context_id") @db.Uuid
  contextLabel String?   @map("context_label")
  status       String    @default("active")
  startsAt     DateTime? @map("starts_at") @db.Date
  endsAt       DateTime? @map("ends_at") @db.Date
  notes        String?
  assignedBy   String?   @map("assigned_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("person_roles")
  @@schema("people")
  @@index([tenantId])
  @@index([customerId])
  @@index([tenantId, role])
}

model PersonTag {
  customerId String    @map("customer_id") @db.Uuid
  tagId      String    @map("tag_id") @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  appliedBy  String?   @map("applied_by")
  appliedAt  DateTime  @default(now()) @map("applied_at")
  expiresAt  DateTime? @map("expires_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([customerId, tagId])
  @@map("person_tags")
  @@schema("people")
  @@index([customerId])
  @@index([tagId])
  @@index([tenantId])
}

model Household {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  members HouseholdMember[]

  @@map("households")
  @@schema("people")
  @@index([tenantId])
}

model HouseholdMember {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  householdId String   @map("household_id") @db.Uuid
  customerId  String   @map("customer_id") @db.Uuid
  role        String   @default("member")
  createdAt   DateTime @default(now()) @map("created_at")

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  customer  Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([householdId, customerId])
  @@map("household_members")
  @@schema("people")
  @@index([householdId])
  @@index([customerId])
  @@index([tenantId])
}

model PersonRelationship {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  fromCustomerId   String   @map("from_customer_id") @db.Uuid
  toCustomerId     String   @map("to_customer_id") @db.Uuid
  relationship     String   // 'parent' | 'guardian' | 'child' | 'sibling' | 'spouse' | 'other'
  createdAt        DateTime @default(now()) @map("created_at")

  fromCustomer Customer @relation("RelationshipFrom", fields: [fromCustomerId], references: [id], onDelete: Cascade)
  toCustomer   Customer @relation("RelationshipTo",   fields: [toCustomerId],   references: [id], onDelete: Cascade)

  @@unique([fromCustomerId, toCustomerId, relationship])
  @@map("person_relationships")
  @@schema("people")
  @@index([fromCustomerId])
  @@index([toCustomerId])
  @@index([tenantId])
}

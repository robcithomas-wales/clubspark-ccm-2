generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["membership"]
}

model MembershipScheme {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  organisationId String   @map("organisation_id") @db.Uuid
  name           String
  description    String?
  status         String   @default("active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  plans MembershipPlan[]

  @@map("membership_schemes")
  @@schema("membership")
}

model MembershipPlan {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  organisationId   String   @map("organisation_id") @db.Uuid
  schemeId         String   @map("scheme_id") @db.Uuid
  name             String
  code             String?
  description      String?
  ownershipType    String?  @map("ownership_type")
  durationType     String?  @map("duration_type")
  visibility       String?
  status           String   @default("active")
  sortOrder        Int?     @map("sort_order")

  // Phase 1: membership type & structure
  membershipType   String?  @map("membership_type")   // individual | family | group | team | organisation
  sportCategory    String?  @map("sport_category")
  maxMembers       Int?     @map("max_members")        // for family/group/team plans
  isPublic         Boolean  @default(false) @map("is_public")

  // Phase 1: pricing model
  pricingModel     String?  @map("pricing_model")     // fixed | instalment | recurring | variable
  price            Decimal? @db.Decimal(10, 2)
  currency         String   @default("GBP")
  billingInterval  String?  @map("billing_interval")  // monthly | quarterly | annual
  instalmentCount  Int?     @map("instalment_count")

  // Phase 1: eligibility rules (JSONB: minAge, maxAge, requiresExistingMembership, notes, etc.)
  eligibility      Json?

  // Phase 2: grace period and T&C
  gracePeriodDays      Int?    @map("grace_period_days")
  termsAndConditions   String? @map("terms_and_conditions")

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  scheme       MembershipScheme            @relation(fields: [schemeId], references: [id])
  memberships  Membership[]
  entitlements MembershipPlanEntitlement[]

  @@map("membership_plans")
  @@schema("membership")
}

model Membership {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  organisationId String    @map("organisation_id") @db.Uuid
  planId         String    @map("plan_id") @db.Uuid
  customerId     String?   @map("customer_id") @db.Uuid
  ownerType      String?   @map("owner_type")
  ownerId        String?   @map("owner_id") @db.Uuid
  // status: pending | active | suspended | lapsed | cancelled | expired
  status         String    @default("pending")
  startDate      DateTime  @map("start_date") @db.Date
  endDate        DateTime? @map("end_date") @db.Date
  renewalDate    DateTime? @map("renewal_date") @db.Date
  autoRenew      Boolean   @default(false) @map("auto_renew")
  paymentStatus  String?   @map("payment_status")
  reference      String?
  source         String?
  notes          String?

  // Phase 1: lifecycle timestamps
  activatedAt    DateTime? @map("activated_at")
  suspendedAt    DateTime? @map("suspended_at")
  cancelledAt    DateTime? @map("cancelled_at")
  lapsedAt       DateTime? @map("lapsed_at")
  expiredAt      DateTime? @map("expired_at")

  // Phase 2: member role within the plan (player | coach | parent | manager | admin | junior)
  memberRole     String?   @map("member_role")

  // Phase 2: manual payment recording
  paymentRecordedAt DateTime? @map("payment_recorded_at")
  paymentReference  String?   @map("payment_reference")
  paymentMethod     String?   @map("payment_method")
  paymentAmount     Decimal?  @map("payment_amount") @db.Decimal(10, 2)

  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  plan            MembershipPlan           @relation(fields: [planId], references: [id])
  lifecycleEvents MembershipLifecycleEvent[]

  @@map("memberships")
  @@schema("membership")
}

model MembershipLifecycleEvent {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  membershipId String   @map("membership_id") @db.Uuid
  fromStatus   String   @map("from_status")
  toStatus     String   @map("to_status")
  reason       String?
  createdBy    String?  @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")

  membership Membership @relation(fields: [membershipId], references: [id])

  @@map("membership_lifecycle_events")
  @@schema("membership")
}

model EntitlementPolicy {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  organisationId String   @map("organisation_id") @db.Uuid
  name           String
  policyType     String?  @map("policy_type")
  description    String?
  status         String   @default("active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  planEntitlements MembershipPlanEntitlement[]

  @@map("entitlement_policies")
  @@schema("membership")
}

model MembershipPlanEntitlement {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String   @map("tenant_id") @db.Uuid
  planId              String   @map("plan_id") @db.Uuid
  entitlementPolicyId String   @map("entitlement_policy_id") @db.Uuid
  scopeType           String?  @map("scope_type")
  scopeId             String?  @map("scope_id") @db.Uuid
  configuration       Json     @default("{}")
  priority            Int      @default(100)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  plan              MembershipPlan    @relation(fields: [planId], references: [id])
  entitlementPolicy EntitlementPolicy @relation(fields: [entitlementPolicyId], references: [id])

  @@map("membership_plan_entitlements")
  @@schema("membership")
}

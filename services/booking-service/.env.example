PORT=4005
NODE_ENV=development

# Primary database (write)
DATABASE_URL=postgresql://user:password@localhost:5432/clubspark

# Read replica (optional — falls back to DATABASE_URL)
DATABASE_READ_URL=

# Venue service base URL
VENUE_SERVICE_URL=http://localhost:4003

# Tenant IDs for service-to-service calls (pilot only — replace with service tokens in production)
DEFAULT_TENANT_ID=aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa
DEFAULT_ORG_ID=11111111-1111-1111-1111-111111111111

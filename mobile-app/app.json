{
  "expo": {
    "name": "Club & Coach",
    "slug": "club-and-coach",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "clubandcoach",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1857E0"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.clubspark.clubandcoach"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1857E0"
      },
      "package": "com.clubspark.clubandcoach"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1857E0"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
